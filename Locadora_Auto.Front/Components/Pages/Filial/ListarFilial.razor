@page "/filiais"
@using Locadora_Auto.Front.Components.Forms
@using Locadora_Auto.Front.Components.Notificacao
@using Locadora_Auto.Front.Components.UI
@using Locadora_Auto.Front.Models.Response
@using Locadora_Auto.Front.Models.Tabelas
@using Locadora_Auto.Front.Services.Servicos.Filial
@using Locadora_Auto.Front.Services.Servicos.Funcionario
@using Locadora_Auto.Front.Services.Utils.Notificacao
@inject NavigationManager Navegacao
@inject IFilialService _filialService
@inject INotificationService NotificacaoService
@inject IConfirmDialogService ConfirmService
@* @attribute [Authorize(Roles = "Administrador, Gerente")] *@
@rendermode InteractiveServer

<!-- Componente de confirmação -->
<ConfirmDialog @ref="confirmDialog" />

<div class="container-fluid py-4">
    <!-- Cabeçalho da página -->
    <div class="row mb-4">
        <div class="col">
            <h2>Filiais</h2>
            <p class="text-muted">Gerencie as filiais do sistema</p>
        </div>
    </div>

    <!-- Tabela genérica de categorias -->
    <TabelaGenerica TItem="FilialResponse"
                    @bind-PaginaAtual="paginaAtual"
                    @bind-ItensPorPagina="itensPorPagina"
                    @bind-OrdenacaoPropriedade="ordenacaoPropriedade"
                    @bind-OrdenacaoDirecao="ordenacaoDirecao"
                    @bind-TermoBusca="termoBuscaGlobal"
                    Items="filiais"
                    TotalItens="totalItems"
                    Colunas="colunas"
                    Carregando="carregando"
                    OnCarregarDados="CarregarFiliais"
                    Titulo="Filiais"
                    PlaceholderBusca="Pesquisar por nome..."
                    SelecaoHabilitada="true"
                    LarguraColunaAcoes="200"
                    Acoes="acoes"
                    AcoesEmMassa="acoesEmMassa"
                    ObterId="@(c => c.IdFilial.ToString())"
                    IconeVazio="bi-tags"
                    MensagemVazio="Nenhuma filial encontrada"
                    MensagemVazioDetalhe="Clique em 'Nova Filial' para começar">

        <!-- Ações no cabeçalho -->
        <AcoesCabecalho>
            <a href="/filial/nova" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-circle me-1"></i>Nova Filial
            </a>
        </AcoesCabecalho>
    </TabelaGenerica>
</div>

@code {
    // ===== REFERÊNCIA PARA O COMPONENTE DE CONFIRMAÇÃO =====
    private ConfirmDialog? confirmDialog;

    // ===== VARIÁVEIS DE ESTADO =====
    private List<FilialResponse> filiais = new();
    private bool carregando;
    private int totalItems;
    private int paginaAtual = 1;
    private int itensPorPagina = 10;
    private string? ordenacaoPropriedade;
    private string ordenacaoDirecao = "asc";
    private string termoBuscaGlobal = string.Empty;

    // ===== DEFINIÇÃO DAS COLUNAS DA TABELA =====
    private List<ColunaTabela<FilialResponse>> colunas = new()
    {
        new()
        {
            Titulo = "Nome",
            Propriedade = "Nome",
            Largura = "350",
            Ordenavel = true
        },
        new()
        {
            Titulo = "Cidade",
            Propriedade = "Cidade",
             Largura = "350",
            Ordenavel = true
        }
    };

    // ===== AÇÕES INDIVIDUAIS =====
    private List<AcaoTabela<FilialResponse>> acoes => new()
    {
        new()
        {
            Titulo = "Visualizar",
            Icone = "bi-eye",
            Cor = "info",
            Acao = async (c) => Navegacao.NavigateTo($"/filial/visualizar/{c.IdFilial}")
        },
        new()
        {
            Titulo = "Editar",
            Icone = "bi-pencil",
            Cor = "primary",
            Acao = async (c) => Navegacao.NavigateTo($"/filial/editar/{c.IdFilial}")
        },
        new()
        {
            Titulo = "Fotos",
            Icone = "bi-camera",
            Cor = "success",
            Acao = async (c) => Navegacao.NavigateTo($"/filial/{c.IdFilial}/fotos")
        },
        new()
        {
            Titulo = "Excluir",
            Icone = "bi-trash",
            Cor = "danger",
            Acao = async (c) => await ExcluirFiliais(c.IdFilial.ToString(), c.Nome)
        }
    };

    // ===== AÇÕES EM MASSA =====
    private List<AcaoEmMassa> acoesEmMassa => new()
    {
        new()
        {
            Titulo = "Exportar selecionados",
            Icone = "bi-file-earmark-excel",
            Cor = "success",
            Acao = async (ids) => await ExportarSelecionados(ids),
            MostrarQuantidade = true
        },
        new()
        {
            Titulo = "Excluir selecionados",
            Icone = "bi-trash",
            Cor = "danger",
            Acao = async (ids) => await ExcluirSelecionados(ids),
            MostrarQuantidade = true
        }
    };

    // ===== MÉTODOS DO CICLO DE VIDA =====
    protected override async Task OnInitializedAsync()
    {
        await CarregarFiliais();
    }

    // ===== MÉTODO PRINCIPAL DE CARREGAMENTO =====
    private async Task CarregarFiliais()
    {
        carregando = true;
        StateHasChanged();

        try
        {
            var resultado = await _filialService.ObterTodos(
                nome: string.IsNullOrWhiteSpace(termoBuscaGlobal) ? null : termoBuscaGlobal.Trim(),
                pagina: paginaAtual,
                itensPorPagina: itensPorPagina);

            filiais = resultado?.Items?.ToList() ?? new();
            totalItems = resultado?.Total ?? 0;
        }
        catch (Exception ex)
        {
            NotificacaoService.ShowError($"Erro ao carregar filiais: {ex.Message}", "Erro");
            filiais = new();
            totalItems = 0;
        }
        finally
        {
            carregando = false;
            StateHasChanged();
        }
    }

    // ===== AÇÕES INDIVIDUAIS =====
    private async Task ExcluirFiliais(string id, string nome)
    {
        var confirmado = await ConfirmService.ConfirmAsync(
            $"Deseja realmente excluir a filial '{nome}'? Esta ação não pode ser desfeita.",
            "Confirmar Exclusão");

        if (confirmado)
        {
            try
            {
                var sucesso = await _filialService.Excluir(id);
                if (sucesso)
                {
                    NotificacaoService.ShowSuccess($"Filial {nome} excluída com sucesso!", "Exclusão");

                    if (filiais.Count == 1 && paginaAtual > 1)
                    {
                        paginaAtual--;
                    }

                    await CarregarFiliais();
                }
                else
                {
                    NotificacaoService.ShowError($"Erro ao excluir filial.", "Erro");
                }
            }
            catch (Exception ex)
            {
                NotificacaoService.ShowError($"Erro ao excluir: {ex.Message}", "Erro");
            }
        }
    }

    // ===== AÇÕES EM MASSA =====
    private async Task ExportarSelecionados(List<string> ids)
    {
        var nomes = filiais
            .Where(c => ids.Contains(c.IdFilial.ToString()))
            .Select(c => c.Nome)
            .ToList();

        NotificacaoService.ShowInfo($"Exportando {ids.Count} filiais: {string.Join(", ", nomes)}", "Exportação");
        // TODO: Implementar exportação real (Excel, CSV, etc)
    }

    private async Task ExcluirSelecionados(List<string> ids)
    {
        var confirmado = await ConfirmService.ConfirmAsync(
            $"Deseja realmente excluir {ids.Count} Filial(s)? Esta ação não pode ser desfeita.",
            "Confirmar Exclusão em Massa");

        if (confirmado)
        {
            var sucessos = 0;
            var erros = 0;

            foreach (var id in ids)
            {
                try
                {
                    var sucesso = await _filialService.Excluir(id);
                    if (sucesso)
                        sucessos++;
                    else
                        erros++;
                }
                catch
                {
                    erros++;
                }
            }

            if (erros == 0)
            {
                NotificacaoService.ShowSuccess($"{sucessos} filial(s) excluída(s) com sucesso!", "Sucesso");

                if (filiais.Count == ids.Count && paginaAtual > 1)
                {
                    paginaAtual--;
                }
            }
            else
            {
                NotificacaoService.ShowWarning($"{sucessos} excluídas, {erros} falhas", "Atenção");
            }

            await CarregarFiliais();
        }
    }
}