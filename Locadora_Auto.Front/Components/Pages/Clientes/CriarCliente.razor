@page "/clientes/novo"
@using Blazored.FluentValidation
@using Locadora_Auto.Front.Components.Forms
@using Locadora_Auto.Front.Models.Enum
@using Locadora_Auto.Front.Models.Request
@using Locadora_Auto.Front.Models.Request.Cliente
@using Locadora_Auto.Front.Models.Response
@using Locadora_Auto.Front.Models.Validadores
@using Locadora_Auto.Front.Services.Servicos.Funcionario
@using Locadora_Auto.Front.Services.Servicos.Notificacao
@inject NavigationManager Navegacao
@inject INotificationService NotificacaoService
@inject IClienteService ClienteService
@inject IServiceProvider ProvedorServicos
@* @attribute [Authorize(Roles = "Administrador")] *@
@rendermode InteractiveServer

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h2>Novo cliente</h2>
            <p class="text-muted">Preencha os dados para cadastrar um novo cliente</p>
        </div>
    </div>

    <EditForm Model="@usuario" OnValidSubmit="@ManipularEnvio" Context="formContext">
        <FluentValidationValidator @ref="validadorFluent" />

        <div class="row">
            <div class="col-md-6">
                <!-- Dados pessoais -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Dados Pessoais</h5>
                    </div>
                    <div class="card-body">
                        <!-- Número Habilitação -->
                        <div class="mb-3">
                            <label class="form-label">Número habilitação <span class="text-danger">*</span></label>
                            <InputText @bind-Value="usuario.NumeroHabilitacao" class="form-control" placeholder="Digite o número da sua habilitação" />
                            <ValidationMessage For="@(() => usuario.NumeroHabilitacao)" />
                        </div>

                        <!-- Validade Habilitação -->
                        <div class="mb-3">
                            <label class="form-label">Validade habilitação <span class="text-danger">*</span></label>
                            <InputDate @bind-Value="usuario.ValidadeHabilitacao" class="form-control" placeholder="Digite a Validade da sua habilitação" />
                            <ValidationMessage For="@(() => usuario.ValidadeHabilitacao)" />
                        </div>

                        <!-- Nome -->
                        <div class="mb-3">
                            <label class="form-label">Nome Completo <span class="text-danger">*</span></label>
                            <InputText @bind-Value="usuario.Nome" class="form-control" placeholder="Digite o nome completo" />
                            <ValidationMessage For="@(() => usuario.Nome)" />
                        </div>

                        <!-- CPF com máscara -->
                        <InputCPF @bind-Value="usuario.Cpf" Label="CPF:" Placeholder="Digite o CPF" />
                        <ValidationMessage For="@(() => usuario.Cpf)" />
                    </div>
                </div>

                <!-- Contato -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Contato</h5>
                    </div>
                    <div class="card-body">
                        <!-- E-mail -->
                        <div class="mb-3">
                            <label class="form-label">E-mail <span class="text-danger">*</span></label>
                            <InputText @bind-Value="usuario.Email"  class="form-control" type="email" placeholder="email@exemplo.com" />
                            <ValidationMessage For="@(() => usuario.Email)" />
                        </div>

                        <!-- Telefone com máscara -->
                        <InputTelefone @bind-Value="usuario.Telefone" Label="Telefone para Contato" Placeholder="(00) 00000-0000" />
                        <ValidationMessage For="@(() => usuario.Telefone)" />
                    </div>
                </div>

                <!-- Segurança -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Segurança</h5>
                    </div>
                    <div class="card-body">
                        <!-- Senha -->
                        <div class="mb-3">
                            <label class="form-label">Senha <span class="text-danger">*</span></label>
                            <InputText type="password"
                                       @bind-Value="usuario.Senha"
                                       class="form-control"
                                       placeholder="Mínimo 6 caracteres" />
                            <ValidationMessage For="@(() => usuario.Senha)" />
                            <small class="text-muted">
                                A senha deve conter letras maiúsculas, minúsculas e números
                            </small>
                        </div>

                        <!-- Confirme Senha -->
                        <div class="mb-3">
                            <label class="form-label">Confirme a Senha <span class="text-danger">*</span></label>
                            <InputText type="password"
                                       @bind-Value="usuario.ConfirmeSenha"
                                       class="form-control"
                                       placeholder="Digite a senha novamente" />
                            <ValidationMessage For="@(() => usuario.ConfirmeSenha)" />
                        </div>

                        <!-- Indicador de força da senha -->
                        @if (!string.IsNullOrEmpty(usuario.Senha))
                        {
                            <div class="mt-2">
                                <label class="small">Força da senha:</label>
                                <div class="progress" style="height: 5px;">
                                    <div class="progress-bar @ObterClasseForcaSenha()"
                                         style="width: @(ObterForcaSenha() * 20)%"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <EnderecoForm @bind-Endereco="usuario.Endereco" Titulo="Endereço do Cliente" />              
            </div>
        </div>

        <div class="row mt-3">
            <div class="col">
                <div class="d-flex gap-2 justify-content-end">
                    <button type="button" class="btn btn-secondary" @onclick="Cancelar" @onclick:preventDefault="false">
                        <i class="bi bi-x-circle me-1"></i>Cancelar
                    </button>
                    <button type="submit" class="btn btn-primary" disabled="@processando">
                        @if (processando)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            <span>Salvando...</span>
                        }
                        else
                        {
                            <i class="bi bi-check-circle me-1"></i>
                            <span>Salvar Usuário</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </EditForm>
</div>

@code {
    // ===== VARIÁVEIS DE ESTADO DO COMPONENTE =====

    /// <summary>
    /// Armazena os dados do formulário de cliente sendo preenchido
    /// </summary>
    private ClienteRequest usuario = new()
    {
        Endereco = new EnderecoRequest()
    };


    // Controla o estado de processamento (loading) para evitar múltiplos envios
    private bool processando;


    // Referência para o validador FluentValidation usado no formulário
    private FluentValidationValidator? validadorFluent;







    // ===== MÉTODOS DE VALIDAÇÃO DE SENHA =====

    /// <summary>
    /// Calcula a força da senha baseado em critérios de complexidade
    /// Retorna um valor de 0 a 5 quanto mais forte a senha
    /// </summary>
    /// <returns>Número inteiro representando a força (0-5)</returns>
    private int ObterForcaSenha()
    {
        if (string.IsNullOrEmpty(usuario.Senha)) return 0;

        int forca = 0;

        // Critérios de avaliação da senha
        if (usuario.Senha.Length >= 6) forca++; // Tamanho mínimo
        if (usuario.Senha.Any(char.IsUpper)) forca++; // Tem maiúscula
        if (usuario.Senha.Any(char.IsLower)) forca++; // Tem minúscula
        if (usuario.Senha.Any(char.IsDigit)) forca++; // Tem número
        if (usuario.Senha.Any(c => !char.IsLetterOrDigit(c))) forca++; // Tem caractere especial

        return forca;
    }

    /// <summary>
    /// Retorna a classe CSS apropriada para a barra de progresso
    /// baseado na força da senha (vermelho, amarelo, azul, verde)
    /// </summary>
    /// <returns>Nome da classe Bootstrap para cor da barra</returns>
    private string ObterClasseForcaSenha()
    {
        return ObterForcaSenha() switch
        {
            0 or 1 => "bg-danger",   // Senha fraca - vermelho
            2 or 3 => "bg-warning",   // Senha média - amarelo
            4 => "bg-info",            // Senha boa - azul
            5 => "bg-success",         // Senha forte - verde
            _ => "bg-secondary"
        };
    }


    // ===== MÉTODOS DE AÇÃO PRINCIPAL =====

    /// <summary>
    /// Processa o envio do formulário quando válido
    /// Valida os dados, chama a API para criar o funcionário
    /// e fornece feedback visual sobre o resultado
    /// </summary>
    private async Task ManipularEnvio()
    {
        processando = true; // Ativa estado de loading
        StateHasChanged(); // Atualiza UI para mostrar spinner no botão

        try
        {
            // Valida o modelo usando FluentValidation
            var validador = new ClienteValidator();
            var resultado = await validador.ValidateAsync(usuario);

            // Se houver erros de validação
            if (!resultado.IsValid)
            {
                // Agrupa os erros por propriedade para exibição organizada
                var erros = resultado.Errors.GroupBy(e => e.PropertyName).ToDictionary(g => g.Key, g => g.Select(e => e.ErrorMessage).ToArray() );

                // Exibe os erros usando o serviço de notificação
                NotificacaoService.ShowValidationErrors(erros);
                processando = false;
                StateHasChanged();
                return;
            }

            // Chama o serviço para inserir o funcionário na API
            var clienteCriado = await ClienteService.Inserir(usuario);

            if (clienteCriado != null)
            {
                // Sucesso - mostra mensagem de confirmação
                NotificacaoService.ShowSuccess("Cliente cadastrado com sucesso!", "Cadastro Realizado");

                // Limpa o formulário para novo cadastro
                usuario = new ClienteRequest()
                {
                    Endereco = new EnderecoRequest()
                };

                // Aguarda 2 segundos para o usuário ver a mensagem de sucesso
                await Task.Delay(2000);

                // Redireciona para a mesma página (limpa o formulário)
                Navegacao.NavigateTo("/clientes/novo");
            }
        }
        catch (Exception ex)
        {
            // Erro na chamada da API - mostra mensagem de erro
            NotificacaoService.ShowError(
                $"Erro ao cadastrar usuário: {ex.Message}",
                "Erro no Cadastro"
            );
        }
        finally
        {
            processando = false; // Desativa estado de loading
            StateHasChanged(); // Atualiza UI
        }
    }

    /// <summary>
    /// Cancela a operação e retorna para a lista de funcionários
    /// Verifica se há dados não salvos antes de sair
    /// </summary>
    private async Task Cancelar()
    {
        // Verifica se existem alterações não salvas no formulário
        if (PossuiAlteracoesNaoSalvas())
        {
            // TODO: Implementar diálogo de confirmação quando o serviço estiver pronto
            // var confirmado = await ConfirmService.ConfirmarAsync(
            //     "Existem dados não salvos. Deseja realmente sair?",
            //     "Cancelar Cadastro"
            // );

            // Por enquanto, navega direto
            Navegacao.NavigateTo("/funcionarios");
        }
        else
        {
            // Sem alterações, navega direto
            Navegacao.NavigateTo("/funcionarios");
        }
    }


    // ===== MÉTODOS AUXILIARES =====

    /// <summary>
    /// Verifica se existem dados preenchidos no formulário que não foram salvos
    /// Útil para confirmar antes de sair da página
    /// </summary>
    /// <returns>True se houver dados não salvos, False se o formulário estiver vazio</returns>
    private bool PossuiAlteracoesNaoSalvas()
    {
        // Verifica cada campo do formulário para ver se foi preenchido
        return !string.IsNullOrEmpty(usuario.NumeroHabilitacao) ||
               !string.IsNullOrEmpty(usuario.Nome) ||
               !string.IsNullOrEmpty(usuario.Cpf) ||
               !string.IsNullOrEmpty(usuario.Email) ||
               !string.IsNullOrEmpty(usuario.Telefone) ||
               !string.IsNullOrEmpty(usuario.Senha); // Verifica se há permissões selecionadas
    }
}