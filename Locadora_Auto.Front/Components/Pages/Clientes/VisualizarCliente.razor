@page "/clientes/visualizar/{id:int}"
@using Locadora_Auto.Front.Components.Forms
@using Locadora_Auto.Front.Models.Enum
@using Locadora_Auto.Front.Models.Response
@using Locadora_Auto.Front.Services.Servicos.Funcionario
@using Locadora_Auto.Front.Services.Servicos.Notificacao
@inject NavigationManager Navegacao
@inject INotificationService NotificacaoService
@inject IClienteService _clienteService
@* @attribute [Authorize(Roles = "Administrador, Gerente")] *@
@rendermode InteractiveServer

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-outline-secondary btn-sm" @onclick="Voltar">
                    <i class="bi bi-arrow-left"></i> Voltar
                </button>
                <h2 class="mb-0">Detalhes do Cliente</h2>
            </div>
            <p class="text-muted mt-2">Visualize as informações completas do cliente</p>
        </div>
    </div>

    @if (carregando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Carregando...</span>
            </div>
            <p class="mt-2">Carregando dados do cliente...</p>
        </div>
    }
    else if (cliente == null)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Cliente não encontrado ou não existe.
        </div>
    }
    else
    {
        <div class="row">
            <!--1ª colunas-->
            <div class="col-md-6">
                <!--card dados pessoais-->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Dados Pessoais</h5>
                        @if (cliente.Ativo == true)
                        {
                            <span class="badge @ObterBadgeStatus()">Ativo</span>
                        }
                        else
                        {
                            <span class="badge @ObterBadgeStatus()">Inativo</span>
                        }

                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold text-muted small">Validade Habilitação</label>
                                <p class="mb-0">@cliente.ValidadeHabilitacao</p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold text-muted small">Numero habilitação</label>
                                <p class="mb-0">@cliente.NumeroHabilitacao</p>
                            </div>
                           
                            <div class="col-12 mb-3">
                                <label class="fw-bold text-muted small">Nome Completo</label>
                                <p class="mb-0 fs-5">@cliente.Nome</p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold text-muted small">CPF</label>
                                <p class="mb-0">@cliente.Cpf</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!--card contatos-->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Contato</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold text-muted small">E-mail</label>
                                <p class="mb-0">
                                    <i class="bi bi-envelope me-1"></i>
                                    <a href="mailto:@cliente.Email">@cliente.Email</a>
                                </p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold text-muted small">Telefone</label>
                                <p class="mb-0">
                                    <i class="bi bi-telephone me-1"></i>
                                    @(cliente.Telefone ?? "Não informado")
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!--2ª colunas-->
            <div class="col-md-6">
               <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Endereço do cliente</h5>                    
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="fw-bold text-muted small">CEP</label>
                            <p class="mb-0">@cliente.Endereco.Cep</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="fw-bold text-muted small">Logradouro</label>
                            <p class="mb-0">@cliente.Endereco.Logradouro</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="fw-bold text-muted small">Numero</label>
                            <p class="mb-0">@cliente.Endereco.Numero</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="fw-bold text-muted small">Bairro</label>
                            <p class="mb-0 fs-5">@cliente.Endereco.Bairro</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="fw-bold text-muted small">Cidade</label>
                            <p class="mb-0">@cliente.Endereco.Cidade</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="fw-bold text-muted small">Estado</label>
                            <p class="mb-0">@cliente.Endereco.Estado</p>
                        </div>
                    </div>
                </div>
            </div>
           </div>
        </div>
        

        <div class="row mt-3">
            <div class="col">
                <div class="d-flex gap-2 justify-content-end">
                    <button type="button" class="btn btn-outline-secondary" @onclick="Voltar">
                        <i class="bi bi-arrow-left me-1"></i>Voltar
                    </button>
                    <a href="/clientes/editar/@id" class="btn btn-primary">
                        <i class="bi bi-pencil me-1"></i>Editar Cliente
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@code {
    // ===== PARÂMETROS DA ROTA =====

    /// <summary>
    /// ID do funcionário obtido da URL
    /// </summary>
    [Parameter] public int id { get; set; }


    // ===== VARIÁVEIS DE ESTADO DO COMPONENTE =====

    /// <summary>
    /// Dados do funcionário carregado da API
    /// </summary>
    private ClienteResponse? cliente;

    /// <summary>
    /// Controla o estado de carregamento (spinner)
    /// </summary>
    private bool carregando = true;


    // ===== MÉTODOS DO CICLO DE VIDA =====

    /// <summary>
    /// Executado quando o parâmetro da rota muda
    /// Permite recarregar os dados se o ID for alterado
    /// </summary>
    protected override async Task OnParametersSetAsync()
    {
        await CarregarCliente();
    }


    // ===== MÉTODOS DE CARREGAMENTO =====

    /// <summary>
    /// Busca os dados do funcionário na API usando o ID da rota
    /// </summary>
    private async Task CarregarCliente()
    {
        try
        {
            carregando = true;
            StateHasChanged();

            cliente = await _clienteService.ObterPorId(id.ToString());
        }
        catch (Exception ex)
        {
            NotificacaoService.ShowError($"Erro ao carregar clientes: {ex.Message}");
            cliente = null;
        }
        finally
        {
            carregando = false;
            StateHasChanged();
        }
    }


    // ===== MÉTODOS DE NAVEGAÇÃO =====

    /// <summary>
    /// Retorna para a lista de funcionários
    /// </summary>
    private void Voltar()
    {
        Navegacao.NavigateTo("/clientes");
    }


    // ===== MÉTODOS AUXILIARES =====

    /// <summary>
    /// Retorna a classe CSS apropriada para o badge de status
    /// </summary>
    private string ObterBadgeStatus()
    {
        string status;
        if (cliente?.Ativo == null) return "bg-secondary";
        if (cliente?.Ativo == true) return "bg-success";
        if (cliente?.Ativo == false) return "bg-bg-danger";
        return "bg-secondary";
    }
}