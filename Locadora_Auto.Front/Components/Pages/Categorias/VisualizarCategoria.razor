@page "/categorias/visualizar/{id:int}"
@using Locadora_Auto.Front.Components.Forms
@using Locadora_Auto.Front.Models.Enum
@using Locadora_Auto.Front.Models.Response
@using Locadora_Auto.Front.Services.Servicos.Funcionario
@using Locadora_Auto.Front.Services.Utils.Notificacao
@inject NavigationManager Navegacao
@inject INotificationService NotificacaoService
@inject ICategoriaService _categoriaService
@* @attribute [Authorize(Roles = "Administrador, Gerente")] *@
@rendermode InteractiveServer

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-outline-secondary btn-sm" @onclick="Voltar">
                    <i class="bi bi-arrow-left"></i> Voltar
                </button>
                <h2 class="mb-0">Detalhes da categoria</h2>
            </div>
            <p class="text-muted mt-2">Visualize as informações completas da categoria</p>
        </div>
    </div>

    @if (carregando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Carregando...</span>
            </div>
            <p class="mt-2">Carregando dados da categoria...</p>
        </div>
    }
    else if (categoria == null)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Categoria não encontrado ou não existe.
        </div>
    }
    else
    {
        <div class="row">
            <!--1ª colunas-->
            <div class="col-md-6">
                <!--card dados pessoais-->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Categoria</h5>                       

                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold text-muted small">Nome</label>
                                <p class="mb-0">@categoria.Nome</p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold text-muted small">Valor da diaria</label>
                                <p class="mb-0">@categoria.ValorDiaria</p>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold text-muted small">Limite por Kilometro</label>
                                <p class="mb-0">@categoria.LimiteKm</p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold text-muted small">Valor do Km excedente</label>
                                <p class="mb-0">@categoria.ValorKmExcedente</p>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold text-muted small">Total de veicúlos</label>
                                <p class="mb-0">@categoria.Totalveiculos</p>
                            </div>
                         </div>
                    </div>
                </div>
            </div>


        </div>
        

        <div class="row mt-3">
            <div class="col">
                <div class="d-flex gap-2 justify-content-end">
                    <button type="button" class="btn btn-outline-secondary" @onclick="Voltar">
                        <i class="bi bi-arrow-left me-1"></i>Voltar
                    </button>
                    <a href="/categorias/editar/@id" class="btn btn-primary">
                        <i class="bi bi-pencil me-1"></i>Editar Categoria
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@code {
    // ===== PARÂMETROS DA ROTA =====

    /// <summary>
    /// ID do funcionário obtido da URL
    /// </summary>
    [Parameter] public int id { get; set; }


    // ===== VARIÁVEIS DE ESTADO DO COMPONENTE =====

    /// <summary>
    /// Dados do funcionário carregado da API
    /// </summary>
    private CategoriaResponse? categoria;

    /// <summary>
    /// Controla o estado de carregamento (spinner)
    /// </summary>
    private bool carregando = true;


    // ===== MÉTODOS DO CICLO DE VIDA =====

    /// <summary>
    /// Executado quando o parâmetro da rota muda
    /// Permite recarregar os dados se o ID for alterado
    /// </summary>
    protected override async Task OnParametersSetAsync()
    {
        await CarregarCategoria();
    }


    // ===== MÉTODOS DE CARREGAMENTO =====

    /// <summary>
    /// Busca os dados do funcionário na API usando o ID da rota
    /// </summary>
    private async Task CarregarCategoria()
    {
        try
        {
            carregando = true;
            StateHasChanged();

            categoria = await _categoriaService.ObterPorId(id.ToString());
        }
        catch (Exception ex)
        {
            NotificacaoService.ShowError($"Erro ao carregar clientes: {ex.Message}");
            categoria = null;
        }
        finally
        {
            carregando = false;
            StateHasChanged();
        }
    }


    // ===== MÉTODOS DE NAVEGAÇÃO =====

    /// <summary>
    /// Retorna para a lista de funcionários
    /// </summary>
    private void Voltar()
    {
        Navegacao.NavigateTo("/categorias");
    }    
}