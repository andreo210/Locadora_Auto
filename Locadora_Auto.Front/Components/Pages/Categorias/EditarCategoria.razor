@page "/categorias/editar/{id:int}"
@using Blazored.FluentValidation
@using Locadora_Auto.Front.Components.Forms
@using Locadora_Auto.Front.Models.Request.Categoria
@using Locadora_Auto.Front.Models.Response
@using Locadora_Auto.Front.Models.Validadores
@using Locadora_Auto.Front.Services.Servicos.Funcionario
@using Locadora_Auto.Front.Services.Utils.Notificacao
@inject NavigationManager Navegacao
@inject INotificationService NotificacaoService
@inject ICategoriaService _categoriaService
@inject ILogger<EditarCategoria> Logger
@* @attribute [Authorize(Roles = "Administrador")] *@
@rendermode InteractiveServer

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-outline-secondary btn-sm" @onclick="Voltar">
                    <i class="bi bi-arrow-left"></i> Voltar
                </button>
                <h2 class="mb-0">Editar Categoria</h2>
            </div>
            <p class="text-muted mt-2">Altere os dados da categoria</p>
        </div>
    </div>

    @if (carregando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Carregando...</span>
            </div>
            <p class="mt-2">Carregando dados da categoria...</p>
        </div>
    }
    else if (categoriaOriginal == null)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Categoria não encontrada ou não existe.
        </div>
    }
    else
    {
        <EditForm Model="@categoriaEdit" OnValidSubmit="@ManipularEnvio">
            <FluentValidationValidator @ref="validadorFluent" />

            <div class="row">
                <div class="col-md-8 mx-auto">
                    <div class="card shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">Dados da Categoria</h5>
                        </div>
                        <div class="card-body">
                            <!-- Nome -->
                            <div class="mb-3">
                                <label class="form-label">Nome <span class="text-danger">*</span></label>
                                <InputText @bind-Value="categoriaEdit.Nome" class="form-control" placeholder="Digite o nome da categoria" />
                                <ValidationMessage For="@(() => categoriaEdit.Nome)" />
                            </div>

                            <!-- Valor da diária - usando InputMoeda -->
                            <div class="mb-3">
                                <label class="form-label">Valor da diária <span class="text-danger">*</span></label>
                                <!-- Usando InputMoeda com double -->
                                <InputMoeda @bind-Value="categoriaEdit.ValorDiaria"
                                            placeholder="R$ 0,00" />
                                <ValidationMessage For="@(() => categoriaEdit.ValorDiaria)" />
                            </div>

                            <!-- Limite de Km -->
                            <div class="mb-3">
                                <label class="form-label">Limite de Km <span class="text-danger">*</span></label>
                                <InputMoeda @bind-Value="categoriaEdit.ValorDiaria"
                                            placeholder="R$ 0,00" />
                                <ValidationMessage For="@(() => categoriaEdit.LimiteKm)" />
                            </div>

                            <!-- Valor do km excedente - usando InputMoeda -->
                            <div class="mb-3">
                                <label class="form-label">Valor do km excedente <span class="text-danger">*</span></label>
                                <!-- Usando InputMoeda com double -->
                                <InputMoeda @bind-Value="categoriaEdit.ValorDiaria"
                                            placeholder="R$ 0,00" />
                                <ValidationMessage For="@(() => categoriaEdit.ValorKmExcedente)" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col">
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-secondary" @onclick="Cancelar">
                            <i class="bi bi-x-circle me-1"></i>Cancelar
                        </button>
                        <button type="submit" class="btn btn-primary" disabled="@processando">
                            @if (processando)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                <span>Salvando...</span>
                            }
                            else
                            {
                                <i class="bi bi-check-circle me-1"></i>
                                <span>Salvar Alterações</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </EditForm>
    }
</div>

@code {
    // ===== PARÂMETROS DA ROTA =====
    [Parameter] public int id { get; set; }

    // ===== VARIÁVEIS DE ESTADO DO COMPONENTE =====
    private AtualizarCategoriaRequest? categoriaEdit;
    private CategoriaResponse? categoriaOriginal;
    private bool carregando = true;
    private bool processando;
    private FluentValidationValidator? validadorFluent;

    // ===== MÉTODOS DO CICLO DE VIDA =====
    protected override async Task OnParametersSetAsync()
    {
        await CarregarDadosCategoria();
    }

    // ===== MÉTODO DE CARREGAMENTO =====
    private async Task CarregarDadosCategoria()
    {
        try
        {
            carregando = true;
            StateHasChanged();

            categoriaOriginal = await _categoriaService.ObterPorId(id.ToString());

            if (categoriaOriginal == null)
            {
                Logger.LogWarning("Categoria não encontrada: {CategoriaId}", id);
                NotificacaoService.ShowWarning("Categoria não encontrada", "Atenção");
                return;
            }

            // Mapeia os dados para o request de edição
            categoriaEdit = new AtualizarCategoriaRequest
            {
                Nome = categoriaOriginal.Nome,
                ValorDiaria = categoriaOriginal.ValorDiaria ?? 0,
                LimiteKm = categoriaOriginal.LimiteKm ?? 0,
                ValorKmExcedente = categoriaOriginal.ValorKmExcedente ?? 0
            };

            Logger.LogInformation("Dados da categoria {CategoriaId} carregados com sucesso", id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Erro ao carregar categoria {CategoriaId}", id);
            NotificacaoService.ShowError("Erro ao carregar dados da categoria", "Erro");
        }
        finally
        {
            carregando = false;
            StateHasChanged();
        }
    }

    // ===== MÉTODO PRINCIPAL DE ENVIO =====
    private async Task ManipularEnvio()
    {
        if (categoriaEdit == null || categoriaOriginal == null) return;

        // Validação adicional
        if (!ValidarDados())
            return;

        processando = true;
        StateHasChanged();

        try
        {
            Logger.LogInformation("Atualizando categoria ID: {CategoriaId}", id);

            var sucesso = await _categoriaService.Atualizar(id, categoriaEdit);

            if (sucesso.Value)
            {
                NotificacaoService.ShowSuccess("Categoria atualizada com sucesso!", "Sucesso");
                await Task.Delay(1500);
                Navegacao.NavigateTo($"/categorias/visualizar/{id}");
            }
            else
            {
                Logger.LogWarning("Falha ao atualizar categoria {CategoriaId}", id);
                NotificacaoService.ShowWarning("Não foi possível atualizar a categoria", "Atenção");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "ERRO ao editar categoria {CategoriaId}", id);
            NotificacaoService.ShowError($"Erro ao atualizar categoria: {ex.Message}", "Erro");
        }
        finally
        {
            processando = false;
            StateHasChanged();
        }
    }

    // ===== VALIDAÇÃO ADICIONAL =====
    private bool ValidarDados()
    {
        if (categoriaEdit == null) return false;

        if (string.IsNullOrWhiteSpace(categoriaEdit.Nome))
        {
            NotificacaoService.ShowWarning("O nome da categoria é obrigatório", "Validação");
            return false;
        }

        if (categoriaEdit.ValorDiaria <= 0)
        {
            NotificacaoService.ShowWarning("O valor da diária deve ser maior que zero", "Validação");
            return false;
        }

        if (categoriaEdit.LimiteKm < 0)
        {
            NotificacaoService.ShowWarning("O limite de KM não pode ser negativo", "Validação");
            return false;
        }

        if (categoriaEdit.ValorKmExcedente < 0)
        {
            NotificacaoService.ShowWarning("O valor do KM excedente não pode ser negativo", "Validação");
            return false;
        }

        return true;
    }

    // ===== MÉTODOS DE NAVEGAÇÃO =====
    private void Voltar()
    {
        if (PossuiAlteracoesNaoSalvas())
        {
            // TODO: Implementar diálogo de confirmação
            Navegacao.NavigateTo($"/categorias/visualizar/{id}");
        }
        else
        {
            Navegacao.NavigateTo($"/categorias/visualizar/{id}");
        }
    }

    private void Cancelar() => Voltar();

    private bool PossuiAlteracoesNaoSalvas()
    {
        if (categoriaEdit == null || categoriaOriginal == null) return false;

        return categoriaEdit.Nome != categoriaOriginal.Nome ||
               Math.Abs(categoriaEdit.LimiteKm - (categoriaOriginal.LimiteKm ?? 0)) > 0 ||
               Math.Abs(categoriaEdit.ValorKmExcedente - (categoriaOriginal.ValorKmExcedente ?? 0)) > 0.01 ||
               Math.Abs(categoriaEdit.ValorDiaria - (categoriaOriginal.ValorDiaria ?? 0)) > 0.01;
    }
}