@page "/categorias/editar/{id:int}"
@using Blazored.FluentValidation
@using Locadora_Auto.Front.Components.Forms
@using Locadora_Auto.Front.Components.Pages.Clientes
@using Locadora_Auto.Front.Models.Enum
@using Locadora_Auto.Front.Models.Request
@using Locadora_Auto.Front.Models.Request.Categoria
@using Locadora_Auto.Front.Models.Request.Cliente
@using Locadora_Auto.Front.Models.Response
@using Locadora_Auto.Front.Models.Validadores
@using Locadora_Auto.Front.Services.Servicos.Funcionario
@using Locadora_Auto.Front.Services.Utils.Notificacao
@inject NavigationManager Navegacao
@inject INotificationService NotificacaoService
@inject ICategoriaService _categoriaService
@inject ILogger<EditarCliente> Logger
@* @attribute [Authorize(Roles = "Administrador")] *@
@rendermode InteractiveServer

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-outline-secondary btn-sm" @onclick="Voltar">
                    <i class="bi bi-arrow-left"></i> Voltar
                </button>
                <h2 class="mb-0">Editar Categoria</h2>
            </div>
            <p class="text-muted mt-2">Altere os dados da categoria</p>
        </div>
    </div>

    @if (carregando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Carregando...</span>
            </div>
            <p class="mt-2">Carregando dados do categoria...</p>
        </div>
    }
    else if (categoriaOriginal == null)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Categoria não encontrado ou não existe.
        </div>
    }
    else
    {
        <EditForm Model="@categoriaEdit" OnValidSubmit="@ManipularEnvio" Context="formContext">
            <FluentValidationValidator @ref="validadorFluent" />

            <div class="row">
                <!-- 1ª coluna -->
                <div class="col-md-6">
                    <!-- Card Dados pessoais -->
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Categoria</h5>
                        </div>
                        <div class="card-body">
                            <!-- Nome -->
                            <div class="mb-3">
                                <label class="form-label">Nome <span class="text-danger">*</span></label>
                                <InputText @bind-Value="categoriaEdit.Nome" class="form-control" placeholder="Digite o nome da categoria" />
                                <ValidationMessage For="@(() => categoriaEdit.Nome)" />
                            </div>

                            <!-- Valor da diaria -->
                            <div class="mb-3">
                                <label class="form-label">Valor da diária <span class="text-danger">*</span></label>
                                <InputNumber @bind-Value="categoriaEdit.ValorDiaria" class="form-control" placeholder="Digite o valor da diaria" />
                                <ValidationMessage For="@(() => categoriaEdit.ValorDiaria)" />
                            </div>

                            <!-- Nome -->
                            <div class="mb-3">
                                <label class="form-label">Limite de Km <span class="text-danger">*</span></label>
                                <InputNumber @bind-Value="categoriaEdit.LimiteKm" class="form-control" placeholder="Digite o nome completo" />
                                <ValidationMessage For="@(() => categoriaEdit.LimiteKm)" />
                            </div>

                            <!-- CPF com máscara -->
                            <div class="mb-3">
                                <label class="form-label">Valor do km excedente <span class="text-danger">*</span></label>
                                <InputNumber @bind-Value="categoriaEdit.ValorKmExcedente" class="form-control" placeholder="Digite o valor do km excedente" />
                                <ValidationMessage For="@(() => categoriaEdit.ValorKmExcedente)" />
                            </div>
                        </div>
                    </div>                   
                </div>                
            </div>

            <div class="row mt-3">
                <div class="col">
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-secondary" @onclick="Cancelar">
                            <i class="bi bi-x-circle me-1"></i>Cancelar
                        </button>
                        <button type="submit" class="btn btn-primary" disabled="@processando">
                            @if (processando)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                <span>Salvando...</span>
                            }
                            else
                            {
                                <i class="bi bi-check-circle me-1"></i>
                                <span>Salvar Alterações</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </EditForm>
    }
</div>

@code {
    // ===== PARÂMETROS DA ROTA =====
    [Parameter] public int id { get; set; }

    // ===== VARIÁVEIS DE ESTADO DO COMPONENTE =====
    private CriarCategoriaRequest? categoriaEdit;
    private CategoriaResponse? categoriaOriginal;
    private bool carregando = true;
    private bool processando;
    private bool alterarSenha = false;
    private string novaSenha = string.Empty;
    private string confirmeNovaSenha = string.Empty;
    private FluentValidationValidator? validadorFluent;

    // ===== MÉTODOS DO CICLO DE VIDA =====
    protected override async Task OnParametersSetAsync()
    {
        await CarregarDadosCategoria();
    }

    // ===== MÉTODO DE CARREGAMENTO =====
    private async Task CarregarDadosCategoria()
    {
        try
        {
            carregando = true;
            StateHasChanged();

            categoriaOriginal = await _categoriaService.ObterPorId(id.ToString());

            if (categoriaOriginal == null)
            {
                Logger.LogWarning("Cliente não encontrado: {ClienteId}", id);
                NotificacaoService.ShowWarning("Cliente não encontrado", "Atenção");
                return;
            }

            // Mapeia os dados para o request de edição
            categoriaEdit = new CriarCategoriaRequest
            {
                LimiteKm = categoriaOriginal.LimiteKm.Value,
                ValorKmExcedente = categoriaOriginal.ValorKmExcedente.Value,
                ValorDiaria = categoriaOriginal.ValorDiaria.Value,
                Nome = categoriaOriginal.Nome
            };

            Logger.LogInformation("Dados do cliente {ClienteId} carregados com sucesso", id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Erro ao carregar cliente {ClienteId}", id);
            NotificacaoService.ShowError("Erro ao carregar dados do cliente", "Erro");
        }
        finally
        {
            carregando = false;
            StateHasChanged();
        }
    }



    // ===== MÉTODO PRINCIPAL DE ENVIO =====
    private async Task ManipularEnvio()
    {
        if (categoriaEdit == null || categoriaOriginal == null) return;

        processando = true;
        StateHasChanged();

        try
        {
            Logger.LogInformation("Atualizando cliente ID: {ClienteId}", id);

            // Cria o request de atualização
            var updateRequest = new CriarCategoriaRequest
            {
                LimiteKm = categoriaEdit.LimiteKm,
                ValorKmExcedente = categoriaEdit.ValorKmExcedente,
                ValorDiaria = categoriaEdit.ValorDiaria,
                Nome = categoriaEdit.Nome
            };


            var resultado = await _categoriaService.Atualizar(id, updateRequest);

            if (resultado != null && resultado.Value)
            {
                NotificacaoService.ShowSuccess("Categoria atualizado com sucesso!", "Sucesso");
                await Task.Delay(1500);
                Navegacao.NavigateTo($"/categorias/visualizar/{id}");
            }
            else
            {
                Logger.LogWarning("Falha ao atualizar categoria {Id}", id);
                await Task.Delay(1500);
                NotificacaoService.ShowWarning("Não foi possível atualizar o cliente", "Atenção");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "ERRO ao editar categoria {Id}", id);
            NotificacaoService.ShowError($"Erro ao atualizar categoria: {ex.Message}", "Erro");
        }
        finally
        {
            processando = false;
            StateHasChanged();
        }
    }

    // ===== MÉTODOS DE NAVEGAÇÃO =====
    private void Voltar()
    {
        if (PossuiAlteracoesNaoSalvas())
        {
            // Aqui você pode implementar um diálogo de confirmação
            Navegacao.NavigateTo($"/categorias/visualizar/{id}");
        }
        else
        {
            Navegacao.NavigateTo($"/categorias/visualizar/{id}");
        }
    }

    private void Cancelar() => Voltar();

    private bool PossuiAlteracoesNaoSalvas()
    {
        if (categoriaEdit == null || categoriaOriginal == null) return false;

        return categoriaEdit.Nome != categoriaOriginal.Nome ||
               categoriaEdit.LimiteKm != categoriaOriginal.LimiteKm ||
               categoriaEdit.ValorKmExcedente != categoriaOriginal.ValorKmExcedente ||
               categoriaEdit.ValorDiaria != categoriaOriginal.ValorDiaria;
    }

    
}