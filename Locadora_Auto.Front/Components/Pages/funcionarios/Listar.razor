    private async Task DesativarFuncionario(string id, string nome)
    {
        var confirmado = await ConfirmService.ConfirmAsync(

           $"Deseja realmente desativar o funcionário '{nome}'?",
           "Confirmar Exclusão"
       );

        if (confirmado)
        {
            try
            {
                var sucesso = await FuncionarioService.Desativar(id);
                if (sucesso)
                {
                    NotificacaoService.ShowSuccess($"Funcionário {nome} desativado com sucesso!", "Exclusão");

                    // Se a página atual ficar vazia, volta uma página
                    if (funcionarios.Count == 1 && paginaAtual > 1)
                    {
                        paginaAtual--;
                    }

                    await CarregarFuncionarios(); // Recarrega a lista
                }
            }
            catch (Exception ex)
            {
                NotificacaoService.ShowError($"Erro ao ativar: {ex.Message}", "Erro");
            }
        }
    }


