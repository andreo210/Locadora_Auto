@page "/funcionarios"
@using Locadora_Auto.Front.Components.UI
@using Locadora_Auto.Front.Components.Notificacao
@using Locadora_Auto.Front.Models.Response
@using Locadora_Auto.Front.Models.Enum
@using Locadora_Auto.Front.Models.Tabelas
@using Locadora_Auto.Front.Services.Servicos.Funcionario
@using Locadora_Auto.Front.Services.Servicos.Notificacao
@inject NavigationManager Navegacao
@inject IFuncionarioService FuncionarioService
@inject INotificationService NotificacaoService
@inject IConfirmDialogService ConfirmService
@* @attribute [Authorize(Roles = "Administrador, Gerente")] *@
@rendermode InteractiveServer

<!-- Componente de confirmação -->
<ConfirmDialog @ref="confirmDialog" />

<div class="container-fluid py-4">
    <!-- Cabeçalho da página -->
    <div class="row mb-4">
        <div class="col">
            <h2>Funcionários</h2>
            <p class="text-muted">Gerencie os funcionários do sistema</p>
        </div>
    </div>

    <!-- Tabela genérica de funcionários -->
    <TabelaGenerica TItem="FuncionarioResponse"
                    @bind-PaginaAtual="paginaAtual"
                    @bind-ItensPorPagina="itensPorPagina"
                    @bind-OrdenacaoPropriedade="ordenacaoPropriedade"
                    @bind-OrdenacaoDirecao="ordenacaoDirecao"
                    @bind-TermoBusca="termoBuscaGlobal"
                    Items="funcionarios"
                    TotalItens="totalItems"
                    Colunas="colunas"
                    Carregando="carregando"
                    OnCarregarDados="CarregarFuncionarios"
                    Titulo="Funcionários"
                    PlaceholderBusca="Pesquisar por nome..."
                    SelecaoHabilitada="true"
                    LarguraColunaAcoes="200"
                    Acoes="acoes"
                    AcoesEmMassa="acoesEmMassa"
                    ObterId="@(f => f.IdFuncionario.ToString())"
                    IconeVazio="bi-people"
                    MensagemVazio="Nenhum funcionário encontrado"
                    MensagemVazioDetalhe="Clique em 'Novo Funcionário' para começar">

        <!-- Ações no cabeçalho -->
        <AcoesCabecalho>
            <a href="/funcionarios/novo" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-circle me-1"></i>Novo Funcionário
            </a>
        </AcoesCabecalho>

        <!-- Filtros adicionais -->
        <FiltrosAdicionais>
            <div class="row g-2">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-white">
                            <i class="bi bi-briefcase"></i>
                        </span>
                        <select class="form-select" @bind="filtroCargo">
                            <option value="">Todos os cargos</option>
                            @foreach (var cargo in Enum.GetValues<CargoEnum>())
                            {
                                <option value="@cargo">@cargo.GetDisplayName()</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <select class="form-select" @bind="filtroAtivo">
                        <option value="">Todos os status</option>
                        <option value="true">Ativos</option>
                        <option value="false">Inativos</option>
                    </select>
                </div>
            </div>
        </FiltrosAdicionais>
    </TabelaGenerica>
</div>

@code {
    // ===== REFERÊNCIA PARA O COMPONENTE DE CONFIRMAÇÃO =====
    private ConfirmDialog? confirmDialog;

    // ===== VARIÁVEIS DE ESTADO =====
    private List<FuncionarioResponse> funcionarios = new();
    private bool carregando;
    private int totalItems;
    private int paginaAtual = 1;
    private int itensPorPagina = 10;
    private string? ordenacaoPropriedade;
    private string ordenacaoDirecao = "asc";

    // ===== VARIÁVEIS DE FILTRO =====
    private string _filtroCargo = string.Empty;
    private string filtroCargo
    {
        get => _filtroCargo;
        set
        {
            if (_filtroCargo != value)
            {
                _filtroCargo = value;
                _ = AplicarFiltrosAsync();
            }
        }
    }

    private string _filtroAtivo = string.Empty;
    private string filtroAtivo
    {
        get => _filtroAtivo;
        set
        {
            if (_filtroAtivo != value)
            {
                _filtroAtivo = value;
                _ = AplicarFiltrosAsync();
            }
        }
    }

    private string _termoBuscaGlobal = string.Empty;
    private string termoBuscaGlobal
    {
        get => _termoBuscaGlobal;
        set
        {
            if (_termoBuscaGlobal != value)
            {
                _termoBuscaGlobal = value;
                _ = AplicarFiltrosAsync();
            }
        }
    }

    // ===== DEFINIÇÃO DAS COLUNAS DA TABELA =====
    private List<ColunaTabela<FuncionarioResponse>> colunas = new()
    {
        new()
        {
            Titulo = "Matrícula",
            Propriedade = "Matricula",
            Largura = "120",
            Ordenavel = true
        },
        new()
        {
            Titulo = "Nome",
            Propriedade = "Nome",
            Largura = "200",
            Ordenavel = true
        },
        new()
        {
            Titulo = "Email",
            Propriedade = "Email",
            Largura = "200"
        },
        new()
        {
            Titulo = "Cargo",
            Propriedade = "Cargo",
            Largura = "120",
            Template = (func) => @<span class="badge bg-secondary">@func.Cargo</span>
        },
        new()
        {
            Titulo = "Telefone",
            Propriedade = "Telefone",
            Largura = "120",
            Formato = "(00) 00000-0000"
        },
        new()
        {
            Titulo = "Status",
            Propriedade = "Status",
            Largura = "80",
            Alinhamento = "center",
            Template = (func) => @<span class="badge @(func.Status ? "bg-success" : "bg-danger")">
@(func.Status ? "Ativo" : "Inativo")
</span>
        }
    };

    // ===== AÇÕES INDIVIDUAIS =====
    private List<AcaoTabela<FuncionarioResponse>> acoes => new()
    {
        new()
        {
            Titulo = "Editar",
            Icone = "bi-pencil",
            Cor = "primary",
            Acao = async (f) => Navegacao.NavigateTo($"/funcionarios/editar/{f.IdFuncionario}")
        },
        new()
        {
            Titulo = "Ativar",
            Icone = "bi-arrow-up",
            Cor = "success",
            Acao = async (f) => await AtivarFuncionario(f.IdFuncionario.ToString(), f.Nome)
        },
        new()
        {
            Titulo = "Desativar",
            Icone = "bi-arrow-down",
            Cor = "warning",
            Acao = async (f) => await DesativarFuncionario(f.IdFuncionario.ToString(), f.Nome)
        },
        new()
        {
            Titulo = "Visualizar",
            Icone = "bi-eye",
            Cor = "info",
            Acao = async (f) => Navegacao.NavigateTo($"/funcionarios/visualizar/{f.IdFuncionario}")
        },
        new()
        {
            Titulo = "Excluir",
            Icone = "bi-trash",
            Cor = "danger",
            Acao = async (f) => await ExcluirFuncionario(f.IdFuncionario.ToString(), f.Nome)
        }
    };

    // ===== AÇÕES EM MASSA =====
    private List<AcaoEmMassa> acoesEmMassa => new()
    {
        new()
        {
            Titulo = "Exportar selecionados",
            Icone = "bi-file-earmark-excel",
            Cor = "success",
            Acao = async (ids) => await ExportarSelecionados(ids),
            MostrarQuantidade = true
        },
        new()
        {
            Titulo = "Ativar selecionados",
            Icone = "bi-check-circle-fill",
            Cor = "success",
            Acao = async (ids) => await AtivarSelecionados(ids),
            MostrarQuantidade = true
        },
        new()
        {
            Titulo = "Inativar selecionados",
            Icone = "bi-pause-circle-fill",
            Cor = "warning",
            Acao = async (ids) => await InativarSelecionados(ids),
            MostrarQuantidade = true
        },
        new()
        {
            Titulo = "Excluir selecionados",
            Icone = "bi-trash",
            Cor = "danger",
            Acao = async (ids) => await ExcluirSelecionados(ids),
            MostrarQuantidade = true
        }
    };

    // ===== MÉTODOS DO CICLO DE VIDA =====
    protected override async Task OnInitializedAsync()
    {
        await CarregarFuncionarios();
    }

    // ===== MÉTODO PARA APLICAR FILTROS =====
    private async Task AplicarFiltrosAsync()
    {
        paginaAtual = 1;
        await CarregarFuncionarios();
    }

    // ===== MÉTODO PRINCIPAL DE CARREGAMENTO =====
    private async Task CarregarFuncionarios()
    {
        carregando = true;
        StateHasChanged();

        try
        {
            var resultado = await FuncionarioService.ObterTodos(
                nome: string.IsNullOrWhiteSpace(termoBuscaGlobal) ? null : termoBuscaGlobal.Trim(),
                cargo: string.IsNullOrWhiteSpace(filtroCargo) ? null : filtroCargo,
                ativos: string.IsNullOrEmpty(filtroAtivo) ? null : bool.Parse(filtroAtivo),
                pagina: paginaAtual,
                itensPorPagina: itensPorPagina,
                ordenarPor: ordenacaoPropriedade,
                ordem: ordenacaoDirecao
            );

            funcionarios = resultado.Items ?? new();
            totalItems = resultado.Total;
        }
        catch (Exception ex)
        {
            NotificacaoService.ShowError($"Erro ao carregar funcionários: {ex.Message}", "Erro");
            funcionarios = new();
            totalItems = 0;
        }
        finally
        {
            carregando = false;
            StateHasChanged();
        }
    }

    // ===== AÇÕES INDIVIDUAIS =====
    private async Task ExcluirFuncionario(string id, string nome)
    {
        var confirmado = await ConfirmService.ConfirmAsync(
            $"Deseja realmente excluir o funcionário '{nome}'?",
            "Confirmar Exclusão"
        );

        if (confirmado)
        {
            try
            {
                var sucesso = await FuncionarioService.Excluir(id);
                if (sucesso)
                {
                    NotificacaoService.ShowSuccess($"Funcionário {nome} excluído com sucesso!", "Exclusão");

                    // Se a página atual ficar vazia, volta uma página
                    if (funcionarios.Count == 1 && paginaAtual > 1)
                    {
                        paginaAtual--;
                    }

                    await CarregarFuncionarios();
                }
                else
                {
                    NotificacaoService.ShowError($"Erro ao excluir funcionário.", "Erro");
                }
            }
            catch (Exception ex)
            {
                NotificacaoService.ShowError($"Erro ao excluir: {ex.Message}", "Erro");
            }
        }
    }

    private async Task AtivarFuncionario(string id, string nome)
    {
        var confirmado = await ConfirmService.ConfirmAsync(
            $"Deseja realmente ativar o funcionário '{nome}'?",
            "Confirmar Ativação"
        );

        if (confirmado)
        {
            try
            {
                var sucesso = await FuncionarioService.Ativar(id);
                if (sucesso)
                {
                    NotificacaoService.ShowSuccess($"Funcionário {nome} ativado com sucesso!", "Ativação");
                    await CarregarFuncionarios();
                }
            }
            catch (Exception ex)
            {
                NotificacaoService.ShowError($"Erro ao ativar: {ex.Message}", "Erro");
            }
        }
    }

    private async Task DesativarFuncionario(string id, string nome)
    {
        var confirmado = await ConfirmService.ConfirmAsync(
            $"Deseja realmente desativar o funcionário '{nome}'?",
            "Confirmar Desativação"
        );

        if (confirmado)
        {
            try
            {
                var sucesso = await FuncionarioService.Desativar(id);
                if (sucesso)
                {
                    NotificacaoService.ShowSuccess($"Funcionário {nome} desativado com sucesso!", "Desativação");
                    await CarregarFuncionarios();
                }
            }
            catch (Exception ex)
            {
                NotificacaoService.ShowError($"Erro ao desativar: {ex.Message}", "Erro");
            }
        }
    }

    // ===== AÇÕES EM MASSA =====
    private async Task ExportarSelecionados(List<string> ids)
    {
        var nomes = funcionarios
            .Where(f => ids.Contains(f.IdFuncionario.ToString()))
            .Select(f => f.Nome)
            .ToList();

        NotificacaoService.ShowInfo(
            $"Exportando {ids.Count} funcionários: {string.Join(", ", nomes)}",
            "Exportação"
        );
        // TODO: Implementar exportação real
    }

    private async Task AtivarSelecionados(List<string> ids)
    {
        var confirmado = await ConfirmService.ConfirmAsync(
            $"Deseja realmente ativar {ids.Count} funcionário(s)?",
            "Confirmar Ativação em Massa"
        );

        if (confirmado)
        {
            var sucessos = 0;
            var erros = 0;

            foreach (var id in ids)
            {
                try
                {
                    var sucesso = await FuncionarioService.Ativar(id);
                    if (sucesso)
                        sucessos++;
                    else
                        erros++;
                }
                catch
                {
                    erros++;
                }
            }

            if (erros == 0)
            {
                NotificacaoService.ShowSuccess($"{sucessos} funcionário(s) ativados com sucesso!", "Sucesso");
            }
            else
            {
                NotificacaoService.ShowWarning($"{sucessos} ativados, {erros} falhas", "Atenção");
            }

            await CarregarFuncionarios();
        }
    }

    private async Task InativarSelecionados(List<string> ids)
    {
        var confirmado = await ConfirmService.ConfirmAsync(
            $"Deseja realmente inativar {ids.Count} funcionário(s)?",
            "Confirmar Inativação em Massa"
        );

        if (confirmado)
        {
            var sucessos = 0;
            var erros = 0;

            foreach (var id in ids)
            {
                try
                {
                    var sucesso = await FuncionarioService.Desativar(id);
                    if (sucesso)
                        sucessos++;
                    else
                        erros++;
                }
                catch
                {
                    erros++;
                }
            }

            if (erros == 0)
            {
                NotificacaoService.ShowSuccess($"{sucessos} funcionário(s) inativados com sucesso!", "Sucesso");
            }
            else
            {
                NotificacaoService.ShowWarning($"{sucessos} inativados, {erros} falhas", "Atenção");
            }

            await CarregarFuncionarios();
        }
    }

    private async Task ExcluirSelecionados(List<string> ids)
    {
        var confirmado = await ConfirmService.ConfirmAsync(
            $"Deseja realmente excluir {ids.Count} funcionário(s)? Esta ação não pode ser desfeita.",
            "Confirmar Exclusão em Massa"
        );

        if (confirmado)
        {
            var sucessos = 0;
            var erros = 0;

            foreach (var id in ids)
            {
                try
                {
                    var sucesso = await FuncionarioService.Excluir(id);
                    if (sucesso)
                        sucessos++;
                    else
                        erros++;
                }
                catch
                {
                    erros++;
                }
            }

            if (erros == 0)
            {
                NotificacaoService.ShowSuccess($"{sucessos} funcionário(s) excluídos com sucesso!", "Sucesso");

                // Se a página atual ficar vazia, volta uma página
                if (funcionarios.Count == ids.Count && paginaAtual > 1)
                {
                    paginaAtual--;
                }
            }
            else
            {
                NotificacaoService.ShowWarning($"{sucessos} excluídos, {erros} falhas", "Atenção");
            }

            await CarregarFuncionarios();
        }
    }
}