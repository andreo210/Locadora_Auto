@using Locadora_Auto.Front.Services
@inherits LayoutComponentBase
@inject NavigationManager Navegacao
@inject MenuService ServicoMenu
@inject IJSRuntime JS

<div class="app-layout">
    <aside class="sidebar
    @(SidebarAberta ? "open" : "")
    @(SidebarColapsada ? "collapsed" : "")">

        <!-- BOTÃO DE COLAPSO (DESKTOP) -->
        <div class="sidebar-collapse">
            <img src="/images/logo.png" alt="Logo" class="sidebar-logo" />
            <button @onclick="AlternarColapso">
                <i class="bi @(SidebarColapsada ? "bi-chevron-right" : "bi-chevron-left")"></i>
            </button>
        </div>

        <NavMenu SidebarColapsada="@SidebarColapsada"  OnAlternarColapso="AlternarColapsoDoMenu" />
    </aside>

    @if (SidebarAberta)
    {
        <div class="sidebar-overlay show" @onclick="FecharSidebar"></div>
    }

    <div class="main-area">
        <header class="topbar">
            <button class="menu-toggle" @onclick="AlternarSidebar">
                <span class="bi bi-list"></span>
            </button>

            <div class="page-title">@ObterTituloPaginaAtual()</div>

            <div class="topbar-actions">
                <button class="theme-btn" @onclick="AlternarTema">
                    <span class="bi @(TemaEscuro ? "bi-sun" : "bi-moon")"></span>
                </button>

                <div class="user-topbar" @onclick="AlternarMenuUsuario">
                    <img class="avatar-top" src="@UrlAvatar" />
                    <div class="user-meta">
                        <span class="user-name-top">@NomeUsuario</span>
                        <span class="user-role-top">Administrador</span>
                    </div>
                </div>

                @if (ExibirMenuUsuario)
                {
                    <div class="user-dropdown">
                        <a href="/perfil">Perfil</a>
                        <a href="/configuracoes">Configurações</a>
                        <hr />
                        <a @onclick="Logout">Sair</a>
                    </div>
                }
            </div>
        </header>

        <main class="content">
            @Body
        </main>
    </div>
</div>

@code {
    private bool SidebarColapsada = false;
    private bool SidebarAberta = false;
    private bool TemaEscuro = false;

    private string NomeUsuario = "André Oliveira";
    private string UrlAvatar = "/images/avatar.png";
    private bool ExibirMenuUsuario = false;

    private void AlternarMenuUsuario() => ExibirMenuUsuario = !ExibirMenuUsuario;

    private async Task Logout()
    {
        ExibirMenuUsuario = false;
        Navegacao.NavigateTo("/auth/logout", true);
    }

    private void FecharMenuUsuario() => ExibirMenuUsuario = false;

    private void AlternarColapsoDoMenu()
    {
        SidebarColapsada = !SidebarColapsada;
    }

    private async Task AlternarSidebar()
    {
        SidebarAberta = !SidebarAberta;

        if (SidebarAberta)
            SidebarColapsada = false;
    }

    private void AlternarColapso()
    {
        if (EhMobile())
            return;

        SidebarColapsada = !SidebarColapsada;
    }

    private bool EhMobile() => false; // Futuro ajuste com JS

    private void FecharSidebar() => SidebarAberta = false;

    private async Task AlternarTema()
    {
        TemaEscuro = !TemaEscuro;
        await JS.InvokeVoidAsync("themeManager.setTheme", TemaEscuro);
    }

    private string ObterTituloPaginaAtual()
    {
        var urlAtual = Navegacao.ToBaseRelativePath(Navegacao.Uri);
        return ServicoMenu.GetMenuTitleByUrl(urlAtual) ?? "Dashboard";
    }

    protected override async Task OnAfterRenderAsync(bool primeiraRenderizacao)
    {
        if (primeiraRenderizacao)
        {
            TemaEscuro = await JS.InvokeAsync<bool>("themeManager.loadTheme");
            StateHasChanged();
        }
    }
}