@using Locadora_Auto.Front.Services
@inherits LayoutComponentBase
@inject NavigationManager Navigation

<div class="app-layout">

    <!-- SIDEBAR -->
    <aside class="sidebar @(sidebarOpen ? "open" : "")">
        <NavMenu />
    </aside>

    <!-- OVERLAY MOBILE -->
    <div class="sidebar-overlay @(sidebarOpen ? "show" : "")" @onclick="ToggleSidebar"></div>

    <!-- MAIN AREA -->
    <div class="main-area">
        <header class="topbar px-4">
            <!-- BOTÃO MOBILE -->
            <button class="menu-toggle" @onclick="ToggleSidebar">
                <span class="bi bi-list"></span>
            </button>

            <!-- TÍTULO DINÂMICO -->
            <div class="page-title">@GetCurrentPageTitle()</div>

            <div class="topbar-actions">
                <span class="text-muted small">Locadora System</span>
            </div>
        </header>

        <main class="content px-4 py-4">
            @Body
        </main>
    </div>
</div>

@code {
    private bool sidebarOpen = false;

    private void ToggleSidebar()
    {
        sidebarOpen = !sidebarOpen;
    }

    private string GetCurrentPageTitle()
    {
        var currentUrl = Navigation.ToBaseRelativePath(Navigation.Uri);
        return MenuService.GetMenuTitleByUrl(currentUrl) ?? "Locadora System";
    }

    [Inject] private MenuService MenuService { get; set; } = default!;
}