@using Locadora_Auto.Front.Models
@using Locadora_Auto.Front.Models.Layout
@using Locadora_Auto.Front.Services
@inject NavigationManager Navegacao
@inject MenuService ServicoMenu

<div class="nav-scrollable">
    <nav class="nav">
        @foreach (var itemMenu in _itensMenu)
        {
            @if (itemMenu.SubItens == null || !itemMenu.SubItens.Any())
            {
                <NavLink class="@ObterClasseLink(itemMenu)"
                         href="@itemMenu.Url"
                         Match="NavLinkMatch.Prefix">
                    <span class="nav-icon @($"bi {itemMenu.Icone}")"></span>
                    <span class="nav-text">@itemMenu.Titulo</span>
                </NavLink>
            }
            else
            {
                <div class="nav-group">
                    <div class="@ObterClasseGrupo(itemMenu)" @onclick="() => CliqueGrupo(itemMenu)">
                        <span class="nav-icon @($"bi {itemMenu.Icone}")"></span>
                        <span class="nav-text">@itemMenu.Titulo</span>
                        <span class="nav-arrow @(SubMenuAberto(itemMenu) ? "open" : "")">
                            <span class="bi bi-chevron-down"></span>
                        </span>
                    </div>

                    @if (SubMenuAberto(itemMenu))
                    {
                        <div class="nav-group-items">
                            @foreach (var subItem in itemMenu.SubItens)
                            {
                                <NavLink class="@ObterClasseSubLink(subItem)"
                                         href="@subItem.Url"
                                         Match="NavLinkMatch.Prefix">
                                    <span class="nav-icon @($"bi {subItem.Icone}")"></span>
                                    <span class="nav-text">@subItem.Titulo</span>
                                </NavLink>
                            }
                        </div>
                    }
                </div>
            }
        }

        <NavLink class="nav-link text-danger" href="/auth/logout">
            <span class="nav-icon bi bi-box-arrow-right"></span>
            <span class="nav-text">Sair</span>
        </NavLink>
    </nav>
</div>

@code {
    [Parameter] public bool SidebarColapsada { get; set; }
    [Parameter] public EventCallback OnAlternarColapso { get; set; }

    private List<MenuItem> _itensMenu = new();
    private string? _subMenuAberto;

    protected override void OnInitialized()
    {
        _itensMenu = ServicoMenu.GetMenuItems();

        // Registra para receber notificações de mudança de URL
        Navegacao.LocationChanged += OnLocationChanged;

        // Inicializa com a URL atual
        AtualizarSubMenuPelaUrl(Navegacao.Uri);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        AtualizarSubMenuPelaUrl(e.Location);
        InvokeAsync(StateHasChanged);
    }

    private void AtualizarSubMenuPelaUrl(string url)
    {
        var urlAtual = new Uri(url).AbsolutePath.Trim('/');

        // Procura qual submenu deve estar aberto baseado na URL
        string? novoSublMenu = null;

        foreach (var item in _itensMenu)
        {
            if (item.SubItens == null) continue;

            foreach (var subItem in item.SubItens)
            {
                var urlSubItem = subItem.Url.Trim('/');

                // Verifica se a URL atual corresponde exatamente a este subitem
                if (urlAtual.Equals(urlSubItem, StringComparison.OrdinalIgnoreCase))
                {
                    novoSublMenu = item.Titulo;
                    break;
                }
            }

            if (novoSublMenu != null) break;
        }

        _subMenuAberto = novoSublMenu;
    }

    private async Task CliqueGrupo(MenuItem itemMenu)
    {
        if (SidebarColapsada)
        {
            await OnAlternarColapso.InvokeAsync();
            AlternarSubMenu(itemMenu);
            return;
        }

        AlternarSubMenu(itemMenu);
    }

    private void AlternarSubMenu(MenuItem itemMenu)
    {
        if (_subMenuAberto == itemMenu.Titulo)
        {
            _subMenuAberto = null;
        }
        else
        {
            _subMenuAberto = itemMenu.Titulo;
        }
        StateHasChanged();
    }

    private bool SubMenuAberto(MenuItem itemMenu) => _subMenuAberto == itemMenu.Titulo;

    private bool EstaAtivo(MenuItem itemMenu)
    {
        if (string.IsNullOrEmpty(itemMenu.Url)) return false;

        var urlAtual = Navegacao.ToBaseRelativePath(Navegacao.Uri).Trim('/');
        var urlItem = itemMenu.Url.Trim('/');

        // COMPARAÇÃO EXATA - apenas URLs idênticas são consideradas ativas
        return urlAtual.Equals(urlItem, StringComparison.OrdinalIgnoreCase);
    }

    private string ObterClasseLink(MenuItem itemMenu)
    {
        return EstaAtivo(itemMenu) ? "nav-link active" : "nav-link";
    }

    private string ObterClasseSubLink(MenuItem subItem)
    {
        return EstaAtivo(subItem) ? "nav-link active" : "nav-link";
    }

    private string ObterClasseGrupo(MenuItem itemMenu)
    {
        // Um grupo está ativo APENAS se ele mesmo estiver aberto OU se algum subitem estiver ativo
        var grupoAtivo = SubMenuAberto(itemMenu) ||
                        (itemMenu.SubItens?.Any(s => EstaAtivo(s)) ?? false);

        return grupoAtivo ? "nav-group-header active" : "nav-group-header";
    }

    public void Dispose()
    {
        Navegacao.LocationChanged -= OnLocationChanged;
    }
}