@using Locadora_Auto.Front.Models
@using Locadora_Auto.Front.Services
@inject NavigationManager Navigation
@inject MenuService MenuService

<div class="sidebar-header">
    <a class="navbar-brand" href="">
        <span class="bi bi-car-front"></span>
        <span class="brand-text">Locadora System</span>
    </a>
</div>

<div class="nav-scrollable">
    <nav class="nav flex-column">
        @foreach (var menuItem in _menuItems)
        {
            if (menuItem.SubItens?.Any() == true)
            {
                <div class="nav-group">
                    <div class="nav-group-header" @onclick="() => ToggleSubMenu(menuItem)">
                        <span class="nav-group-icon"><span class="@($"bi {menuItem.Icone}")"></span></span>
                        <span class="nav-group-title">@menuItem.Titulo</span>
                        <span class="nav-group-arrow">
                            <span class="bi @(IsSubMenuOpen(menuItem) ? "bi-chevron-up" : "bi-chevron-down")"></span>
                        </span>
                    </div>

                    @if (IsSubMenuOpen(menuItem))
                    {
                        <div class="nav-group-items">
                            @foreach (var subItem in menuItem.SubItens)
                            {
                                <NavLink class="nav-link submenu" href="@subItem.Url" Match="NavLinkMatch.Prefix">
                                    <span class="@($"bi {subItem.Icone}")"></span>
                                    @subItem.Titulo
                                </NavLink>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <NavLink class="nav-link" href="@menuItem.Url" Match="NavLinkMatch.Prefix">
                    <span class="@($"bi {menuItem.Icone}")"></span>
                    @menuItem.Titulo
                </NavLink>
            }
        }

        <div class="nav-divider"></div>

        <!-- LOGOUT -->
        <NavLink class="nav-link text-danger" href="/auth/logout">
            <span class="bi bi-box-arrow-right"></span>
            Sair
        </NavLink>
    </nav>
</div>

@code {
    private List<MenuItem> _menuItems = new();
    private HashSet<string> _openSubMenus = new();

    protected override void OnInitialized()
    {
        _menuItems = MenuService.GetMenuItems();
        OpenMenuByCurrentUrl();
    }

    private void OpenMenuByCurrentUrl()
    {
        var currentUrl = Navigation.ToBaseRelativePath(Navigation.Uri);

        foreach (var item in _menuItems)
        {
            if (item.SubItens?.Any(s => currentUrl.StartsWith(s.Url, StringComparison.OrdinalIgnoreCase)) == true)
            {
                _openSubMenus.Add(item.Titulo);
            }
        }
    }

    private void ToggleSubMenu(MenuItem menuItem)
    {
        if (_openSubMenus.Contains(menuItem.Titulo))
            _openSubMenus.Remove(menuItem.Titulo);
        else
            _openSubMenus.Add(menuItem.Titulo);
    }

    private bool IsSubMenuOpen(MenuItem menuItem) => _openSubMenus.Contains(menuItem.Titulo);
}