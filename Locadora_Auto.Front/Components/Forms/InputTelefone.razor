@namespace Locadora_Auto.Front.Components.Forms
@inherits InputBase<string>
@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="@ContainerClass">
    <label for="@_inputId" class="@LabelClass">@Label</label>

    @* Input controlado manualmente para máscara progressiva *@
    <input type="tel"
           id="@_inputId"
           class="@InputClass"
           @oninput="OnInput"
           @onblur="OnInputBlur"
           maxlength="15"
           placeholder="@Placeholder"
           disabled="@Disabled"
           value="@CurrentValueForDisplay" />

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <span class="text-danger small">@ErrorMessage</span>
    }
</div>

@code {
    private string _inputId = $"tel-{Guid.NewGuid():N}";
    private string _currentDisplayValue = "";

    [Parameter] public string Label { get; set; } = "Telefone";
    [Parameter] public string ContainerClass { get; set; } = "mb-3";
    [Parameter] public string LabelClass { get; set; } = "form-label";
    [Parameter] public string InputClass { get; set; } = "form-control";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public string? Placeholder { get; set; } = "(00) 00000-0000";

    // Propriedade para exibição formatada
    private string CurrentValueForDisplay
    {
        get => _currentDisplayValue;
        set
        {
            _currentDisplayValue = value;
            // Atualiza o valor sem máscara no modelo
            var apenasNumeros = new string(value?.Where(char.IsDigit).ToArray() ?? Array.Empty<char>());
            if (apenasNumeros.Length <= 11)
            {
                CurrentValueAsString = apenasNumeros;
            }
        }
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        // Quando o valor do modelo muda externamente, atualiza a exibição
        if (!string.IsNullOrEmpty(CurrentValue))
        {
            _currentDisplayValue = AplicarMascaraTelefone(CurrentValue);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("mascaras.aplicarMascaraTelefone", _inputId);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Erro ao aplicar máscara Telefone: {ex.Message}");
            }
        }
    }

    private async Task OnInput(ChangeEventArgs e)
    {
        var valorComMascara = e.Value?.ToString() ?? "";
        var apenasNumeros = new string(valorComMascara.Where(char.IsDigit).ToArray());

        if (apenasNumeros.Length <= 11)
        {
            // Atualiza o valor do modelo (sem máscara)
            CurrentValueAsString = apenasNumeros;

            // Aplica a máscara manualmente para feedback imediato
            _currentDisplayValue = AplicarMascaraTelefone(apenasNumeros);
        }
    }

    private void OnInputBlur(FocusEventArgs e)
    {
        // Validação opcional no blur
        if (CurrentValue?.Length == 10 || CurrentValue?.Length == 11)
        {
            // Telefone válido
            Console.WriteLine($"Telefone válido: {CurrentValue}");
        }
    }

    private string AplicarMascaraTelefone(string? valor)
    {
        if (string.IsNullOrEmpty(valor))
            return "";

        var numeros = new string(valor.Where(char.IsDigit).ToArray());

        if (string.IsNullOrEmpty(numeros))
            return "";

        // Máscara progressiva para telefone
        return numeros.Length switch
        {
            1 => $"({numeros}",
            2 => $"({numeros}",
            3 => $"({numeros.Substring(0, 2)}) {numeros.Substring(2)}",
            4 => $"({numeros.Substring(0, 2)}) {numeros.Substring(2)}",
            5 => $"({numeros.Substring(0, 2)}) {numeros.Substring(2)}",
            6 => $"({numeros.Substring(0, 2)}) {numeros.Substring(2, 4)}",
            7 => $"({numeros.Substring(0, 2)}) {numeros.Substring(2, 4)}-{numeros.Substring(6)}",
            8 => $"({numeros.Substring(0, 2)}) {numeros.Substring(2, 4)}-{numeros.Substring(6)}",
            9 => $"({numeros.Substring(0, 2)}) {numeros.Substring(2, 5)}-{numeros.Substring(7)}",
            10 => $"({numeros.Substring(0, 2)}) {numeros.Substring(2, 4)}-{numeros.Substring(6, 4)}",
            11 => $"({numeros.Substring(0, 2)}) {numeros.Substring(2, 5)}-{numeros.Substring(7, 4)}",
            _ => numeros
        };
    }

    protected override bool TryParseValueFromString(string? value, out string? result, out string? validationErrorMessage)
    {
        result = new string(value?.Where(char.IsDigit).ToArray() ?? Array.Empty<char>());
        validationErrorMessage = null;
        return true;
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("mascaras.removerMascara", _inputId);
        }
        catch
        {
            // Ignora erros no dispose
        }
    }
}