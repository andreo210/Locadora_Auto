@* Components/Forms/InputCEP.razor *@
@namespace Locadora_Auto.Front.Components.Forms
@inherits InputBase<string>

<input type="text"
       id="@_inputId"
       class="@CssClass"
       value="@CurrentValueFormatado"
       @oninput="OnInput"
       maxlength="9"
       placeholder="00000-000"
       disabled="@Disabled" />

@code {
    private string _inputId = $"cep-{Guid.NewGuid():N}";

    [Parameter] public string CssClass { get; set; } = "form-control";
    [Parameter] public bool Disabled { get; set; }

    private string CurrentValueFormatado => AplicarMascaraCep(CurrentValue);

    private void OnInput(ChangeEventArgs e)
    {
        var valorDigitado = e.Value?.ToString() ?? "";
        var apenasNumeros = new string(valorDigitado.Where(char.IsDigit).ToArray());

        if (apenasNumeros.Length <= 8)
        {
            CurrentValueAsString = apenasNumeros;
        }
    }

    private string AplicarMascaraCep(string? cep)
    {
        if (string.IsNullOrEmpty(cep))
            return "";

        var numeros = new string(cep.Where(char.IsDigit).ToArray());

        if (numeros.Length <= 5)
            return numeros;

        return $"{numeros.Substring(0, 5)}-{numeros.Substring(5)}";
    }

    protected override bool TryParseValueFromString(string? value, out string? result, out string? validationErrorMessage)
    {
        result = new string(value?.Where(char.IsDigit).ToArray() ?? Array.Empty<char>());
        validationErrorMessage = null;
        return true;
    }
}